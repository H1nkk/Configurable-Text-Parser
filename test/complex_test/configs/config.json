{
    "sensors": [
        {
            "name": "sensor1",
            "rule": "Датчик 1"
        },
        {
            "name": "sensor2",
            "rule": "Датчик 2"
        },
        {
            "name": "sensor3",
            "rule": "Датчик 3"
        },
        {
            "name": "sensor4",
            "rule": "Датчик 4"
        },
        {
            "name": "sensor5",
            "rule": "Датчик 5"
        }
    ],
    "rules": [
        {
            "name": "state",
            "type": "bool",
            "rule": "Состояние: (.*)",
            "true": "включен",
            "false": "выключен"
        },
        {
            "name": "temp",
            "type": "value",
            "rule": "Температура: (.*)"
        },
        {
            "name": "speed",
            "type": "speed",
            "rule": "Скорость: (.*) (.*)/s"
        }
    ],
    "extractors": [
        {
            "sensor": "sensor1",
            "rules": [
                "temp",
                "speed"
            ]
        },
        {
            "sensor": "sensor2",
            "rules": [
                "state",
                "speed"
            ]
        },
        {
            "sensor": "sensor3",
            "rules": [
                "state",
                "temp"
            ]
        },
        {
            "sensor": "sensor4",
            "rules": [
                "temp",
                "speed"
            ]
        },
        {
            "sensor": "sensor5",
            "rules": [
                "state",
                "speed"
            ]
        }
    ]
}